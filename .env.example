# --- Server ---
PORT=3000
NODE_ENV=development

# --- SeekDB (MySQL-compatible, port 2881) ---
# Create a dedicated DB user for the app, not root.
# Inside the container:
#   ALTER USER 'root' IDENTIFIED BY '<root-password>';
#   CREATE USER 'toocr' IDENTIFIED BY '<app-password>';
#   GRANT ALL PRIVILEGES ON tocr.* TO 'toocr';
DB_HOST=127.0.0.1
DB_PORT=2881
DB_USER=toocr
DB_PASSWORD=change-me
DB_NAME=tocr

# --- Master key for encrypting tenant API credentials in DB ---
# Generate with: bun -e "console.log(crypto.getRandomValues(new Uint8Array(32)).toBuffer().toString('base64'))"
# 32 bytes, base64-encoded. Keep this OUT of git. Loss = lose all stored API keys.
MASTER_KEY_BASE64=

# --- Default tenant for single-tenant MVP ---
DEFAULT_TENANT_ID=1
