# Toptier AI OCR — production env
# Copy to .env on the EC2 host (chmod 600), fill in real values, never commit.

# --- SeekDB ---
DB_ROOT_PASSWORD=change-me-strong
DB_USER=toocr
DB_PASSWORD=change-me-strong-too
DB_NAME=tocr

# --- App ---
# Generate with: openssl rand -base64 32
MASTER_KEY_BASE64=

# --- Cloudflare tunnel token (from `cloudflared tunnel token <TUNNEL_ID>`) ---
CLOUDFLARED_TUNNEL_TOKEN=
